# ~/.config/direnv/templates/api-keys.envrc
# Usage:
#   cp ~/.config/direnv/templates/api-keys.envrc .envrc
#   direnv allow
#
# Requirements:
#   - 1Password CLI (`op`) installed and signed in
#   - direnv installed

# Fail early if required commands are missing.
command -v op >/dev/null || {
  echo "[direnv] op command not found (install 1Password CLI)" >&2
  exit 1
}

# Optional: pick vault/item names by environment variables before sourcing.
#   export OP_VAULT="Private"
#   export OP_ITEM_OPENAI="OpenAI"
#   export OP_ITEM_ANTHROPIC="Anthropic"
: "${OP_VAULT:=Private}"
: "${OP_ITEM_OPENAI:=OpenAI}"
: "${OP_ITEM_ANTHROPIC:=Anthropic}"

# 1Password secret references use this format:
#   op://<Vault>/<Item>/<Field>
# Field names below are examples; match them to your own item fields.
export OPENAI_API_KEY="$(op read "op://${OP_VAULT}/${OP_ITEM_OPENAI}/API key")"
export ANTHROPIC_API_KEY="$(op read "op://${OP_VAULT}/${OP_ITEM_ANTHROPIC}/API key")"

# Add more services as needed:
# export GITHUB_TOKEN="$(op read 'op://Private/GitHub/Personal Access Token')"
# export STRIPE_API_KEY="$(op read 'op://Private/Stripe/Secret key')"
