// =============================================================================
// monitor.kdl - モニタリング用レイアウト
// =============================================================================
// Usage: zellij --layout monitor
//
// ┌────────────────────────────────────────────────────┐
// │              ログ / プロセス監視                     │
// ├────────────────────────┬───────────────────────────┤
// │      ターミナル 1       │      ターミナル 2          │
// └────────────────────────┴───────────────────────────┘
// =============================================================================

layout {
    pane split_direction="horizontal" {
        pane size="50%" {
            name "logs"
        }
        pane split_direction="vertical" size="50%" {
            pane {
                name "shell-1"
                focus true
            }
            pane {
                name "shell-2"
            }
        }
    }
    pane size=1 borderless=true {
        plugin location="compact-bar"
    }
}
