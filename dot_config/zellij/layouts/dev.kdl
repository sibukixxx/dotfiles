// =============================================================================
// dev.kdl - 開発用レイアウト
// =============================================================================
// Usage: zellij --layout dev
//
// ┌────────────────────────────────┬───────────────────┐
// │                                │                   │
// │          エディタ (nvim)        │   ターミナル      │
// │           (60%)                │    (40%)          │
// │                                │                   │
// │                                ├───────────────────┤
// │                                │   git / テスト    │
// │                                │                   │
// └────────────────────────────────┴───────────────────┘
// =============================================================================

layout {
    pane split_direction="vertical" {
        pane size="60%" {
            command "nvim"
            name "editor"
            focus true
        }
        pane split_direction="horizontal" size="40%" {
            pane {
                name "terminal"
            }
            pane {
                name "git/test"
            }
        }
    }
    pane size=1 borderless=true {
        plugin location="compact-bar"
    }
}
